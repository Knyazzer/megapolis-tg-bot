COMPOSE_PROJECT_NAME=megapolis_tg_bot
IMAGE_TAG=latest

APP_URL=https://martis.pro
APP_BIND=127.0.0.1
APP_PORT=3000
APP_TIMEZONE=Europe/Moscow

MYSQL_DATABASE=megapolis_bot
MYSQL_USER=megapolis_bot_user
MYSQL_PASSWORD=change-this-db-password
MYSQL_ROOT_PASSWORD=change-this-root-password

ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=put-bcrypt-hash-here

TELEGRAM_BOT_TOKEN=put-new-token-here
TELEGRAM_WEBHOOK_SECRET=change-this-random-secret
TELEGRAM_REPLY_MODE=webhook
TELEGRAM_DRY_RUN=false
ADMIN_TELEGRAM_IDS=

FACECAST_API_BASE=https://facecast.net/api/v1
FACECAST_UID=put-facecast-uid-here
FACECAST_API_KEY=put-facecast-api-key-here
FACECAST_API_TOKEN=
FACECAST_REGISTRATION_MODE=userreg
FACECAST_REGISTRATION_ENDPOINT=insert_key
FACECAST_USERREG_ENDPOINT=https://kassa.facecast.net/api/viewers/register
FACECAST_CHANNEL_ID=11110
FACECAST_DEFAULT_STREAM_URL=https://facecast.net/w/6k2njf
FACECAST_ACCESS_QUERY_PARAM=key
FACECAST_PASSWORD_QUERY_PARAM=password
FACECAST_DIRECT_LINK_FALLBACK=false
FACECAST_DEMO_MODE=false

WORKER_INTERVAL_MS=60000

TELEGRAM_CHANNEL_URL=https://t.me/megapolismedia
COMPANY_SITE_URL=https://megapolis.media
PRIVACY_URL=https://martis.pro/privacy.php
